# ---------- GoHighLevel ----------
GHL_LOCATION_ID=
# Private Integration Token — must start with "pit-"
GHL_PRIVATE_INTEGRATION_TOKEN=pit-

# ---------- Gmail / automation inbox ----------
# Dedicated Google Workspace mailbox reps BCC / forward to.
AUTOMATION_EMAIL=automation@hellolunajoy.com
# (n8n's Gmail OAuth2 credential handles actual auth; this value is used for
# filtering the automation inbox out of recipient lists.)

# ---------- Filters ----------
# Comma-separated; domains treated as "internal" (automation skips them as
# the sole recipient).
INTERNAL_DOMAINS=hellolunajoy.com,lunajoy.com

# Comma-separated regex patterns matched against the From: address. Any hit
# marks the email as an autoresponder/bounce and skips it.
SKIP_SENDER_PATTERNS=^noreply@,^no-reply@,^mailer-daemon@,^postmaster@,^bounces?@,^calendar-notification@google\.com$

# ---------- Rep → GHL user mapping ----------
# JSON object: lowercase LunaJoy email → GHL userId. Used to assign newly
# created contacts to the rep who originated the email. Optional; unmapped
# reps just won't have assignedTo set.
REP_USER_MAP={"nicole@hellolunajoy.com":"ghl-user-id-nicole","beatriz@hellolunajoy.com":"ghl-user-id-beatriz"}

# ---------- Logging / observability ----------
# Google Sheet ID for the sync_log sheet. (The sheet must have a tab named
# "sync_log" with a header row matching the columns below.)
LOG_SHEET_ID=

# sync_log columns (for reference — create the header row yourself):
# timestamp | rep | externalEmail | type | skipReason | contactId | status |
# errorMessage | subject | gmailMessageId | multiRecipient
