# Supabase — https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — https://platform.openai.com → API Keys
OPENAI_API_KEY=

# GoHighLevel — GHL → Settings → Integrations → Private Integrations
GHL_API_KEY=
GHL_LOCATION_ID=

# Apify — https://console.apify.com → Settings → Integrations
APIFY_API_TOKEN=

# Hunter.io — https://hunter.io → Dashboard → API
HUNTER_API_KEY=

# Google Service Account (for Gmail sending and Google Calendar)
# Create at Google Cloud Console → IAM → Service Accounts
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=
GOOGLE_GMAIL_USER_EMAIL=

# n8n webhook authentication
N8N_WEBHOOK_API_KEY=
